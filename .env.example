# PrecisionPerformance.com Environment Variables Template
# -----------------------------------------------------------------------------
# REQUIRED ACTIONS:
# 1. Copy this file to .env.local
# 2. Populate the exact values from Supabase and Stripe Dashboards
# 3. DO NOT COMMIT .env.local to version control
# -----------------------------------------------------------------------------

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key # Server-side only

# Stripe Integration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... # Use live keys in production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App Environment Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000 # Update to Vercel domain in production
NODE_ENV=development # 'development', 'test', or 'production'
